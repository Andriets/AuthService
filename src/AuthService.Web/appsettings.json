{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "JwtSecret": "REPLACE_WITH_A_SECURE_SECRET_OF_AT_LEAST_32_CHARS",
    "Issuer": "AuthService",
    "Audience": "AuthService",
    "AccessTokenLifetimeHours": 6,
    "RefreshTokenLifetimeDays": 30
  }
}
